{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CognitiveNode",
  "description": "Unidad atómica del grafo de conocimiento de ZENTROPY. Generada por MNENTROPY.",
  "type": "object",
  "required": ["id", "type", "content", "source", "project", "author", "captured_at", "status"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "type": {
      "type": "string",
      "enum": ["insight", "decision", "question", "error", "hypothesis", "pattern", "task", "reference", "observation"]
    },
    "content": {
      "type": "object",
      "required": ["raw", "distilled"],
      "properties": {
        "raw": { "type": "string" },
        "distilled": { "type": "string" },
        "embedding": { "type": "array", "items": { "type": "number" } }
      }
    },
    "source": {
      "type": "object",
      "required": ["system", "type"],
      "properties": {
        "system": { "type": "string", "enum": ["claude_ai", "open_webui", "cursor", "github", "calendar", "filesystem", "browser", "voice", "manual"] },
        "type": { "type": "string", "enum": ["conversation", "commit", "file", "event", "download", "note"] },
        "uri": { "type": "string" },
        "model": { "type": "string" }
      }
    },
    "author": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": { "type": "string", "enum": ["human", "ai", "system"] },
        "human_id": { "type": "string" },
        "ai_model": { "type": "string" }
      }
    },
    "project": { "type": "string", "examples": ["ZENTROPY", "CLAPPS", "NOOS", "KONTABLO"] },
    "tags": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["active", "resolved", "archived", "review_required", "blocked"] },
    "priority": { "type": "string", "enum": ["critical", "high", "medium", "low", "none"] },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "novelty": { "type": "string", "enum": ["reinforcement", "extension", "rupture"] },
    "action_required": { "type": "boolean" },
    "action_description": { "type": "string" },
    "publishable": {
      "type": "object",
      "properties": {
        "is_public": { "type": "boolean" },
        "scope": { "type": "string", "enum": ["private", "team", "public", "publication"] }
      }
    },
    "energy_cost": { "type": "string", "enum": ["low", "medium", "high"] },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_id", "relation_type"],
        "properties": {
          "target_id": { "type": "string", "format": "uuid" },
          "relation_type": { "type": "string", "enum": ["depends_on", "contradicts", "extends", "inspired_by", "blocks", "resolves", "similar_to", "implements"] },
          "weight": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
        }
      }
    },
    "temporal": {
      "type": "object",
      "properties": {
        "occurred_at": { "type": "string", "format": "date-time" },
        "captured_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" }
      }
    },
    "version": { "type": "integer", "minimum": 1 },
    "merge_history": { "type": "array", "items": { "type": "string", "format": "uuid" } }
  }
}
