# ═══════════════════════════════════════════════════════════════════
# .env.example — Variables de entorno requeridas
# Copiar a .env y completar los valores reales.
# NUNCA commitear .env — está en .gitignore.
# ═══════════════════════════════════════════════════════════════════

# -- Supabase (si aplica) ------------------------------------------
# SUPABASE_URL=https://[proyecto].supabase.co
# SUPABASE_KEY=[publishable key — para app de usuario]
# SUPABASE_SERVICE_KEY=[service role key — solo scripts locales, nunca producción]

# -- LLM (si aplica) -----------------------------------------------
# LITELLM_MODEL=ollama/llama3.2  # o openai/gpt-4o, anthropic/claude-3-5-sonnet, etc.
# OLLAMA_BASE_URL=http://localhost:11434

# -- Proyecto -------------------------------------------------------
# TENANT_ID=cluciani  # ID del tenant activo
# PROJECT_NAME=[NOMBRE]

# -- Agregar variables específicas del proyecto aquí ---------------
